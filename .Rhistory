geom_sf(
data = parking,
aes(fill = type),
color = NA,
alpha = 0.9
) +
scale_fill_manual(
values = c("surface" = "#E20B3A", "multi-storey" = "#F48701"),
na.value = "grey60",
name = "Parking type"
) +
coord_sf(
xlim = c(bb["xmin"], bb["xmax"]),
ylim = c(bb["ymin"], bb["ymax"]),
expand = FALSE
) +
labs(title = city_name) +
theme_void() +
theme(plot.title = element_text(hjust = 0.5, face = "bold"))
p
empty_sf <- function(crs = 4326) {
st_sf(geometry = st_sfc(crs = crs))
}
get_osm_polys <- function(q) {
x <- osmdata_sf(q)
parts <- list(x$osm_polygons, x$osm_multipolygons)
parts <- parts[!vapply(parts, is.null, logical(1))]
if (!length(parts) || all(vapply(parts, nrow, integer(1)) == 0)) return(empty_sf(4326))
dplyr::bind_rows(parts) |> st_transform(4326)
}
get_osm_lines <- function(q) {
x <- osmdata_sf(q)
parts <- list(x$osm_lines, x$osm_multilines)
parts <- parts[!vapply(parts, is.null, logical(1))]
if (!length(parts) || all(vapply(parts, nrow, integer(1)) == 0)) return(empty_sf(4326))
dplyr::bind_rows(parts) |> st_transform(4326)
}
# Rivers as lines (typical OSM tagging)
rivers <- get_osm_lines(
opq(bbox = bb) |>
add_osm_feature(key = "waterway", value = c("river", "stream", "canal"))
)
water_bay <- get_osm_polys(opq(bbox = bb) |> add_osm_feature(key = "natural", value = "bay"))
# Join water elements
water <- bind_rows(water_nat, water_riv, water_rb, water_bay) |>
st_make_valid() |>
distinct(geometry, .keep_all = TRUE)
# --- PLOT ---
p <- ggplot() +
geom_sf(data = land,  fill = "white",  color = NA) +
geom_sf(data = parks, fill = "#9DBBAE", color = NA, alpha = 0.35) +
geom_sf(data = water, fill = "#AFC7D4", color = NA, alpha = 0.7) +
geom_sf(data = roads, color = "#949E9E", linewidth = 0.25, alpha = 0.3) +
geom_sf(
data = parking,
aes(fill = type),
color = NA,
alpha = 0.9
) +
scale_fill_manual(
values = c("surface" = "#E20B3A", "multi-storey" = "#F48701"),
na.value = "grey60",
name = "Parking type"
) +
coord_sf(
xlim = c(bb["xmin"], bb["xmax"]),
ylim = c(bb["ymin"], bb["ymax"]),
expand = FALSE
) +
labs(title = city_name) +
theme_void() +
theme(plot.title = element_text(hjust = 0.5, face = "bold"))
p
