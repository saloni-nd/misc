get_osm_polys <- function(q) {
x <- osmdata_sf(q)
parts <- Filter(
function(z) !is.null(z) && inherits(z, "sf") && nrow(z) > 0,
list(x$osm_polygons, x$osm_multipolygons)
)
if (length(parts) == 0) {
return(st_sf(geometry = st_sfc(), crs = 4326))
}
bind_rows(parts) |> st_transform(4326)
}
get_osm_lines <- function(q) {
x <- osmdata_sf(q)
parts <- Filter(
function(z) !is.null(z) && inherits(z, "sf") && nrow(z) > 0,
list(x$osm_lines, x$osm_multilines)
)
if (length(parts) == 0) {
return(st_sf(geometry = st_sfc(), crs = 4326))
}
bind_rows(parts) |> st_transform(4326)
}
rivers <- get_osm_lines(opq(bbox = bb) |> add_osm_feature("waterway", "river"))
water_nat <- get_osm_polys(opq(bbox = bb) |> add_osm_feature("natural", "water"))
water_bay <- get_osm_polys(opq(bbox = bb) |> add_osm_feature(key = "natural", value = "bay"))
# Join water elements
water <- bind_rows(water_nat, water_riv, water_rb, water_bay) |>
st_make_valid() |>
distinct(geometry, .keep_all = TRUE)
# --- PLOT ---
