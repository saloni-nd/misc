) +
scale_fill_manual(
values = c("surface" = "#E20B3A", "multi-storey" = "#F48701"),
na.value = "grey60",
name = "Parking type"
) +
coord_sf(
xlim = c(bb["xmin"], bb["xmax"]),
ylim = c(bb["ymin"], bb["ymax"]),
expand = FALSE
) +
labs(title = city_name) +
theme_void() +
theme(plot.title = element_text(hjust = 0.5, face = "bold"))
p
ggsave(paste0(file_path, "toronto_parking_map.svg"), p, height = 5, width = 6)
ggsave(paste0(file_path, "toronto_parking_map.pdf"), p, height = 5, width = 6)
install.packages("MEPS")
