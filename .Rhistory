name = "Parking type"
) +
coord_sf(
xlim = c(bb["xmin"], bb["xmax"]),
ylim = c(bb["ymin"], bb["ymax"]),
expand = FALSE
) +
labs(title = city_name) +
theme_void() +
theme(plot.title = element_text(hjust = 0.5, face = "bold"))
